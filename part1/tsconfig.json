{
    "compilerOptions": {
        "target": "ES6",                          // Compiled to ES6, compatible with all browsers
        "module": "ES6",                          // Module Specification
        "outDir":"./dist",                        // Restore and merge into a single app.js
        "strict": true,                           // Strict type checking
        "esModuleInterop": true,                  // Compatible module import
        "skipLibCheck": true,                     // Skip library check
        "forceConsistentCasingInFileNames": true, // Ensure file names are case-consistent
    },
    "include": ["./app.ts"]
}